# Required
OAK_DISCORD_TOKEN=

# Recommended for admin-only commands such as /oak-config and service restarts.
OAK_OWNER_ID=

# Optional Codex process settings.
OAK_CODEX_BIN=codex
OAK_CODEX_WS_URL=ws://127.0.0.1:4789

# Optional defaults for new threads.
OAK_CODEX_MODEL=gpt-5.5
OAK_CODEX_REASONING_EFFORT=high
OAK_CODEX_REASONING_SUMMARY=concise
# Valid values depend on the account and model.
OAK_CODEX_SERVICE_TIER=fast

# Optional runtime tuning.
OAK_TURN_TIMEOUT_MS=3600000
OAK_TYPING_INTERVAL_MS=8000

# Optional first-run bootstrap. Paths are resolved relative to the repo root.
OAK_BOOTSTRAP_WORKSPACE_ROOT=
OAK_BOOTSTRAP_WORKSPACE_KEY=default
OAK_BOOTSTRAP_GUILD_ID=
OAK_BOOTSTRAP_CHANNEL_ID=
OAK_BOOTSTRAP_ALLOWED_USER_IDS=
